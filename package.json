{
	"name": "portfolio-website",
	"private": true,
	"version": "0.0.1",
	"dependencies": {
		"@biomejs/biome": "2.2.0",
		"@prisma/client-runtime-utils": "7.5.0"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"husky": "^8.0.0",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9.3"
	},
	"scripts": {
		"prepare": "husky install",
		"clean": "rm -rf packages/db/dist apps/web/.next apps/api/dist node_modules/.cache .turbo",
		"reset": "pnpm clean && pnpm install && pnpm -r build",
		"import:old-solves": "tsx scripts/import-old-solves.ts"
	},
	"lint-staged": {
		"*.{js,ts,tsx,json}": [
			"biome check --write"
		]
	}
}
