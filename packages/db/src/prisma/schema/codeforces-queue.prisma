model CodeforcesSubmissionQueue {
  id           Int              @id @default(autoincrement())
  platform     SolvePlatform    @default(CODEFORCES)
  status       SubmissionStatus @default(PENDING_TIME)
  username     String
  submissionId Int
  contestId    Int
  problemIndex String
  problemName  String
  rating       Int?
  solvedAt     DateTime
  durationMin  Int?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@unique([submissionId])
  @@index([username])
  @@index([status])
  @@index([solvedAt])
}