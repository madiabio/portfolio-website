model LeetcodeSolve {
  id                 Int       @id @default(autoincrement())
  platform           SolvePlatform @default(LEETCODE)
  problemNumber      Int
  problemName        String
  difficulty         String
  durationMin        Int
  solvedAt           DateTime
  notes              String?
  solvedWithoutHint  Boolean?
  solvedOptimally    Boolean?
  createdAt          DateTime  @default(now())
}
